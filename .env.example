DEBUG=0
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
ALLOWED_HOSTS=qr.akadmvd.uz,localhost,127.0.0.1
BACKEND_URL=https://qr.akadmvd.uz
FRONTEND_URL=https://qr.akadmvd.uz
FRONTEND_ALLOWED_ORIGINS=https://qr.akadmvd.uz,http://localhost:4173,http://localhost:5173
USE_X_FORWARDED_HOST=0
# If you serve plain HTTP directly from Gunicorn, set the three flags below to 0.
# If TLS terminates at Gunicorn, Cloudflare, or another edge proxy, keep them at 1.
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=1
# Optional when serving HTTPS directly from Gunicorn:
# GUNICORN_CERTFILE=/etc/ssl/certs/your-domain.crt
# GUNICORN_KEYFILE=/etc/ssl/private/your-domain.key
# If you deploy behind a reverse proxy that sets X-Forwarded-Host, change USE_X_FORWARDED_HOST back to 1.
